mixin sprintDashboard(event)
    section.sprint-dashboard.page-section.bg-light#dashboard
        .container
            .row.g-4
                .col-lg-4
                    .card.dashboard-card.h-100
                        .card-body.text-center
                            .dashboard-icon
                                i.fas.fa-hourglass-half
                            h3.dashboard-card-title.text-uppercase Countdown
                            #countdown.countdown-display Loading…
                            p.dashboard-note.mb-0 Counting down to 09:00 #{event.eventTimeZoneLabel} on Day 1.
                .col-lg-4
                    .card.dashboard-card.h-100
                        .card-body
                            .dashboard-icon.text-center
                                i.fas.fa-calendar-alt
                            h3.dashboard-card-title.text-uppercase.text-center May 2026
                            #calendar.calendar-host Loading…
                            p.dashboard-note.mb-0.text-center.mt-2
                                | Sprint days are highlighted. Today is outlined.
                .col-lg-4
                    .card.dashboard-card.h-100
                        .card-body
                            .dashboard-icon.text-center
                                i.fas.fa-globe
                            h3.dashboard-card-title.text-uppercase.text-center Time Zones
                            .table-responsive.timezone-host
                                table.table.table-sm.mb-0#timezone-table
                                    thead
                                        tr
                                            th Location
                                            th.text-end Local
                                            th.text-end vs. London
                                    tbody
                            p.dashboard-note.mb-0.text-center.mt-2
                                | Listed west→east. The highlighted row is the event time.
            script.
                window.SPRINT_EVENT = !{JSON.stringify(event)};
