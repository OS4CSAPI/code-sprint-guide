mixin sprintDashboard(event)
    section.sprint-hero
        .container
            .text-center.mb-4
                h1.display-5.mb-2= event.title
                p.lead.text-muted.mb-1= event.subtitle
                p.text-muted.mb-0
                    | #{event.venue.name} &middot; 
                    a(href=event.venue.mapsUrl, target='_blank', rel='noopener')= event.venue.address
                p.text-muted.small.mb-0
                    | #{new Date(event.startDateTimeISO).toUTCString().slice(0,16)} – #{new Date(event.endDateTimeISO).toUTCString().slice(0,16)} &middot; #{event.eventTimeZoneLabel}
            .row.g-3
                .col-md-6
                    .card.h-100
                        .card-body
                            h3.h5.card-title Countdown to Day 1
                            #countdown.countdown-display Loading…
                            p.text-muted.small.mb-0
                                | Counting down to 09:00 #{event.eventTimeZoneLabel} on Day 1.
                .col-md-6
                    .card.h-100
                        .card-body
                            h3.h5.card-title May 2026 Calendar
                            #calendar.calendar-host Loading…
                            p.text-muted.small.mb-0.mt-2
                                | Sprint days are highlighted. Today is outlined.
                .col-12
                    .card
                        .card-body
                            h3.h5.card-title Time-Zone Reference
                            .table-responsive
                                table.table.table-sm.mb-0#timezone-table
                                    thead
                                        tr
                                            th Location
                                            th Time zone
                                            th Local time now
                                            th Offset from London
                                    tbody
            script.
                window.SPRINT_EVENT = !{JSON.stringify(event)};
