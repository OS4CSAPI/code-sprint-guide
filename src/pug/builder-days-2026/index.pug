- var event = eventsById['builder-days-2026'];

doctype html
html(lang='en')
    head
        meta(charset='utf-8')
        meta(name='viewport', content='width=device-width, initial-scale=1, shrink-to-fit=no')
        meta(name='description', content=`Participation guide for the OGC API – Connected Systems community at the ${event.title}, ${event.venue.name}.`)
        meta(name='author', content='OS4CSAPI')
        meta(name='theme-color', content='#212529')

        // Open Graph
        meta(property='og:type', content='website')
        meta(property='og:site_name', content='OS4CSAPI Code Sprint Guide')
        meta(property='og:title', content=`${event.title} — OS4CSAPI`)
        meta(property='og:description', content=`Participation guide for the CSAPI community at the ${event.title}, ${event.venue.name}.`)

        title= `${event.title} — OS4CSAPI Sprint Guide`

        link(rel='icon', type='image/x-icon', href='../assets/favicon.ico')
        link(rel='shortcut icon', type='image/x-icon', href='../assets/favicon.ico')
        link(rel='icon', type='image/png', sizes='192x192', href='../assets/img/logos/os4csapi.png')
        link(rel='apple-touch-icon', href='../assets/img/logos/os4csapi.png')

        // Font Awesome
        script(src='https://use.fontawesome.com/releases/v5.15.3/js/all.js', crossorigin='anonymous')

        // Google Fonts
        link(href='https://fonts.googleapis.com/css?family=Montserrat:400,700', rel='stylesheet', type='text/css')
        link(href='https://fonts.googleapis.com/css?family=Roboto+Slab:400,100,300,700', rel='stylesheet', type='text/css')

        link(href='../css/styles.css', rel='stylesheet')

    body#page-top(data-bs-spy='scroll', data-bs-target='#mainNav', data-bs-offset='74')

        //- Navigation
        nav#mainNav.navbar.navbar-expand-lg.navbar-dark.fixed-top
            .container
                a.navbar-brand(href='#page-top') OS4CSAPI · Sprint Guide
                button.navbar-toggler(type='button', data-bs-toggle='collapse', data-bs-target='#navbarResponsive', aria-controls='navbarResponsive', aria-expanded='false', aria-label='Toggle navigation')
                    | Menu
                    i.fas.fa-bars.ms-1
                #navbarResponsive.collapse.navbar-collapse
                    ul.navbar-nav.text-uppercase.ms-auto.py-4.py-lg-0
                        li.nav-item: a.nav-link(href='#dashboard') Dashboard
                        li.nav-item: a.nav-link(href='#participate') Participate
                        li.nav-item: a.nav-link(href='#register') Register
                        li.nav-item: a.nav-link(href='#goals') Goals
                        li.nav-item: a.nav-link(href='#talks') Talks
                        li.nav-item: a.nav-link(href='#implementations') Projects
                        li.nav-item: a.nav-link(href='#logistics') Logistics

        //- Masthead
        header.masthead
            .container
                .masthead-heading.text-uppercase= event.title
                .masthead-subheading= event.subtitle
                p.masthead-meta.mb-3
                    | #{new Date(event.startDateTimeISO).toUTCString().slice(0,16)} – #{new Date(event.endDateTimeISO).toUTCString().slice(0,16)} · #{event.eventTimeZoneLabel}
                    br
                    a.masthead-venue-link(href=event.venue.mapsUrl, target='_blank', rel='noopener')= `${event.venue.name} — ${event.venue.address}`
                a.btn.btn-primary.btn-xl.text-uppercase.me-2(href='#talks') See our talks
                a.btn.btn-dark.btn-xl.text-uppercase(href=event.links.register, target='_blank', rel='noopener') Register

        //- Live dashboard (countdown / calendar / time zones)
        include ../includes/dashboard
        +sprintDashboard(event)

        //- Unofficial-companion disclaimer
        section.py-4.bg-white.disclaimer-strip
            .container
                .row.justify-content-center
                    .col-lg-9
                        .alert.alert-info.mb-0.text-center.disclaimer-alert(role='note')
                            i.fas.fa-info-circle.me-2
                            | This is a community-maintained OS4CSAPI companion guide for participants working on OGC API – Connected Systems topics during the sprint. For official event registration, agenda, and venue information, use the
                            |  
                            a(href=event.links.register, target='_blank', rel='noopener') OGC event page
                            |  and 
                            a(href=event.links.wiki, target='_blank', rel='noopener') sprint wiki
                            | .
                        p.text-center.text-muted.small.mt-3.mb-0
                            i.fas.fa-comment-dots.me-2
                            | Comments, questions, or suggestions about this site? Open an issue on 
                            a(href='https://github.com/OS4CSAPI/code-sprint-guide/issues', target='_blank', rel='noopener') the repo
                            | , drop a note in 
                            a(href=event.links.discussions, target='_blank', rel='noopener') OS4CSAPI Discussions
                            | , or email 
                            a(href='mailto:sbolling@riversideresearch.org') sbolling@riversideresearch.org
                            | .

        //- How to participate
        section.page-section.bg-light#participate
            .container
                .text-center
                    h2.section-heading.text-uppercase How to Participate
                    h3.section-subheading.text-muted Choose what works for you. Hybrid is fully supported.
                .row.g-4.row-cols-1.row-cols-md-2.row-cols-xl-5
                    .col
                        .text-center
                            span.fa-stack.fa-3x
                                i.fas.fa-circle.fa-stack-2x.text-primary
                                i.fas.fa-user-plus.fa-stack-1x.fa-inverse
                            h4.my-3 Register & Connect
                            p.text-muted
                                | Register (free) on the 
                                a(href=event.links.register, target='_blank', rel='noopener') OGC event page
                                | , then join the 
                                a(href=event.links.discord, target='_blank', rel='noopener') OGC events Discord
                                |  (or the 
                                a(href=event.links.matrix, target='_blank', rel='noopener') Matrix bridge
                                | ).
                    .col
                        .text-center
                            span.fa-stack.fa-3x
                                i.fas.fa-circle.fa-stack-2x.text-primary
                                i.fas.fa-bullseye.fa-stack-1x.fa-inverse
                            h4.my-3 Review our Sprint Goals
                            p.text-muted
                                | Skim the 
                                a(href='#goals') Sprint Goals
                                |  to see what OS4CSAPI participants intend to tackle. Pick a thread that overlaps your interests, or bring your own — anything CSAPI-adjacent is welcome.
                    .col
                        .text-center
                            span.fa-stack.fa-3x
                                i.fas.fa-circle.fa-stack-2x.text-primary
                                i.fas.fa-bullhorn.fa-stack-1x.fa-inverse
                            h4.my-3 Tell OGC what you'll work on
                            p.text-muted
                                | Comment on 
                                a(href='#issue-181') developer-events #181
                                |  — OGC's public "what is everybody working on" thread. CSAPI is currently underrepresented there.
                    .col
                        .text-center
                            span.fa-stack.fa-3x
                                i.fas.fa-circle.fa-stack-2x.text-primary
                                i.fas.fa-comments.fa-stack-1x.fa-inverse
                            h4.my-3 Drop daily notes
                            p.text-muted
                                | Share what you got done each day in the 
                                a(href=event.links.discussions, target='_blank', rel='noopener') OS4CSAPI Discussions
                                |  space — gets aggregated into the daily brief-backs.
                            p.text-muted.small.mb-0
                                | Prefer not to post yourself? Send your update to Sam by any channel and he'll liaise it into Discussions on your behalf, with attribution.
                    .col
                        .text-center
                            span.fa-stack.fa-3x
                                i.fas.fa-circle.fa-stack-2x.text-primary
                                i.fas.fa-microphone.fa-stack-1x.fa-inverse
                            h4.my-3 Attend the Talks
                            p.text-muted
                                | Show up — in person or remote — for the 
                                a(href='#talks') CSAPI-themed talks
                                |  OS4CSAPI members are giving across the three sprint days. Bringing an audience helps signal interest in CSAPI to the wider OGC community.

        //- Registration
        section.page-section#register
            .container
                .text-center
                    h2.section-heading.text-uppercase Registration
                    h3.section-subheading.text-muted Free, but you must register on the OGC event page.
                .row.justify-content-center
                    .col-lg-8.text-center
                        p
                            | The OGC Builder Days Code Sprint is free to attend, in person at Geovation in London or remotely via Microsoft Teams. Registration is required either way — OGC uses it for headcount, the venue list, and the Teams invite.
                        p.mb-4
                            | Already registered for OGC Builder Days the week before? You still need a separate registration for the sprint.
                        a.btn.btn-primary.btn-xl.text-uppercase(href=event.links.register, target='_blank', rel='noopener')
                            i.fas.fa-external-link-alt.me-2
                            | Register on the OGC event page
                        p.text-muted.small.mt-3.mb-0
                            | After registering, join the 
                            a(href=event.links.discord, target='_blank', rel='noopener') OGC events Discord
                            |  so you can find the #connected-systems channel before day one.

        //- Sprint Goals
        section.page-section.bg-light#goals
            .container
                .text-center
                    h2.section-heading.text-uppercase Sprint Goals
                    h3.section-subheading.text-muted What OS4CSAPI is collectively working toward at this sprint.
                .row.justify-content-center
                    .col-lg-9
                        ol.goals-list
                            each goal in event.sprintGoals
                                li= goal
                        p.text-center.text-muted.small.mt-4.mb-0
                            | Goal 6 tracks the official spec repository at 
                            a(href=event.links.csapiSpecRepo, target='_blank', rel='noopener')= event.links.csapiSpecRepo
                            | .

        //- Issue #181 detail
        section.page-section#issue-181
            .container
                .text-center
                    h2.section-heading.text-uppercase About Issue #181
                    h3.section-subheading.text-muted The "what is everybody working on" thread.
                .row.justify-content-center
                    .col-lg-9
                        p
                            | OGC has opened a public GitHub thread, 
                            a(href=event.links.issue181, target='_blank', rel='noopener') opengeospatial/developer-events#181
                            | , inviting every sprint participant to post a comment describing what they plan to work on. It is the most visible single channel for getting your work onto OGC's radar before the sprint starts, and it is read by the organizers, mentors, and other tracks.
                        p
                            | At the moment, the CSAPI community is underrepresented on that thread. If you are happy to post directly, please do — a single short paragraph is enough. If you would prefer not to post yourself, send the same paragraph to Sam (any channel) and it will be posted on your behalf with a clear attribution.
                        .card.shadow-sm.mt-4
                            .card-body
                                p.text-muted.small.mb-2.text-uppercase Suggested template — adapt freely
                                p.fst-italic.mb-0
                                    | I will be working on [project / repo] during the May 2026 sprint as part of the OS4CSAPI community. My focus is [Pub/Sub, Binary, conformance tests, ETL, sample data, server, client, docs — pick what fits]. If anyone is interested in [collaborating on / testing / reviewing] this, please reach out on Discord or in the OS4CSAPI Discussions space.

        //- OS4CSAPI talks during the sprint
        section.page-section.bg-light#talks
            .container
                .text-center
                    h2.section-heading.text-uppercase OS4CSAPI Talks at the Sprint
                    h3.section-subheading.text-muted= event.csapiDay.label
                .row.justify-content-center.mb-4
                    .col-lg-9
                        p.text-center.text-muted
                            | Four OS4CSAPI participants are filling speaking slots on the final afternoon of the sprint, each presenting on a Connected Systems topic. These are individual contributions to the broader OGC Builder Days agenda — not a dedicated CSAPI track. All sessions are accessible in person at Geovation, on Microsoft Teams, and via the #connected-systems Discord channel.
                .row.g-4.align-items-start
                    each talk in event.csapiDay.talks
                        .col-md-6
                            .card.talk-card
                                .card-body
                                    p.talk-time= talk.time
                                    h3.talk-title= talk.title
                                    p.talk-speaker
                                        if talk.speakerUrl
                                            strong: a.speaker-link(href=talk.speakerUrl, target='_blank', rel='noopener')= talk.speaker
                                        else
                                            strong= talk.speaker
                                        |  — 
                                        if talk.affiliationUrl
                                            a.talk-affiliation(href=talk.affiliationUrl, target='_blank', rel='noopener')= talk.affiliation
                                        else
                                            span.talk-affiliation= talk.affiliation
                                    p.talk-summary= talk.summary
                                    details
                                        summary Read the full abstract
                                        p.talk-abstract.mb-0= talk.abstract

        //- Implementations of interest
        section.page-section#implementations
            .container
                .text-center
                    h2.section-heading.text-uppercase Implementations of Interest
                    h3.section-subheading.text-muted Open-source CSAPI projects represented in the OS4CSAPI community.
                .row.g-4.justify-content-center
                    .col-md-5
                        .card.h-100.shadow-sm
                            .card-body
                                h4.text-uppercase.mb-3
                                    i.fas.fa-server.text-primary.me-2
                                    | Servers
                                ul.implementations-list
                                    each impl in event.implementations.servers
                                        li
                                            a(href=impl.url, target='_blank', rel='noopener')= impl.name
                                            span.impl-people= impl.people
                    .col-md-5
                        .card.h-100.shadow-sm
                            .card-body
                                h4.text-uppercase.mb-3
                                    i.fas.fa-laptop-code.text-primary.me-2
                                    | Clients & libraries
                                ul.implementations-list
                                    each impl in event.implementations.clients
                                        li
                                            a(href=impl.url, target='_blank', rel='noopener')= impl.name
                                            span.impl-people= impl.people

        //- Logistics (incl. liaison)
        section.page-section.bg-light#logistics
            .container
                .text-center
                    h2.section-heading.text-uppercase Logistics
                    h3.section-subheading.text-muted Venue, links, and the practical details.
                .row.justify-content-center
                    .col-lg-9
                        dl.row.mb-0
                            dt.col-sm-3.text-uppercase Venue
                            dd.col-sm-9
                                a(href=event.venue.mapsUrl, target='_blank', rel='noopener')= event.venue.address
                            dt.col-sm-3.text-uppercase Microsoft Teams
                            dd.col-sm-9
                                a(href=event.links.teams, target='_blank', rel='noopener') Join the meeting
                                |  &middot; Meeting ID: 291 891 040 830 07 &middot; Passcode: eE7Zb7bh
                            dt.col-sm-3.text-uppercase Discord
                            dd.col-sm-9
                                a(href=event.links.discord, target='_blank', rel='noopener')= event.links.discord
                            dt.col-sm-3.text-uppercase Matrix
                            dd.col-sm-9
                                a(href=event.links.matrix, target='_blank', rel='noopener')= event.links.matrix
                            dt.col-sm-3.text-uppercase Wiki
                            dd.col-sm-9
                                a(href=event.links.wiki, target='_blank', rel='noopener')= event.links.wiki
                            dt.col-sm-3.text-uppercase Registration
                            dd.col-sm-9
                                a(href=event.links.register, target='_blank', rel='noopener')= event.links.register
                            dt.col-sm-3.text-uppercase Hotels
                            dd.col-sm-9
                                | See the 
                                a(href=event.links.wiki + '#period-and-location', target='_blank', rel='noopener') Period and Location
                                |  section of the OGC wiki for recommended hotels and transit notes.
                            dt.col-sm-3.text-uppercase Liaison
                            dd.col-sm-9
                                | Sam Bolling (Riverside Research) is the OS4CSAPI liaison for this sprint. Any update — whether you want it forwarded to OGC, posted on issue #181, or just acknowledged privately — can go through him. Easiest channels: OGC events Discord, OS4CSAPI Discussions, or email.
                            dt.col-sm-3.text-uppercase GitHub
                            dd.col-sm-9
                                a(href='https://github.com/Sam-Bolling', target='_blank', rel='noopener') @Sam-Bolling
                            dt.col-sm-3.text-uppercase Email
                            dd.col-sm-9
                                a(href='mailto:sbolling@riversideresearch.org') sbolling@riversideresearch.org

        //- About OS4CSAPI / Why this page
        section.page-section#about
            .container
                .text-center
                    h2.section-heading.text-uppercase About OS4CSAPI
                    h3.section-subheading.text-muted Open Source for OGC API – Connected Systems.
                .row.justify-content-center
                    .col-lg-9
                        p
                            | OS4CSAPI is a continuing initiative led from inside the OGC API Connected Systems Standards Working Group that aims to collaborate with open-source projects to advance shared goals around the CSAPI standard. The OGC Builder Days Code Sprint in May 2026 is one event in the open-ended series in which OS4CSAPI participates.
                        p.mb-0
                            | This page is an open invitation. If you are working on anything CSAPI-related, in the open, during the timeframe of the sprint — and you would like that work to be visible to the OGC community at the event — then this guide is for you, and you are an OS4CSAPI participant for this sprint. There is no formal membership and no required hours.

        //- Footer
        footer.footer.py-4
            .container
                .row.align-items-center
                    .col-md-4.text-lg-start
                        | © OS4CSAPI 2026
                    .col-md-4.text-center
                        a.link-light.me-3(href=event.links.discussions, target='_blank', rel='noopener') Discussions
                        a.link-light.me-3(href='https://github.com/OS4CSAPI', target='_blank', rel='noopener') OS4CSAPI org
                        a.link-light(href='https://github.com/OS4CSAPI/code-sprint-guide', target='_blank', rel='noopener') Source
                    .col-md-4.text-lg-end
                        small.text-muted Built on the Start Bootstrap "Agency" theme.

        script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js', crossorigin='anonymous')
        script(src='../js/scripts.js')
